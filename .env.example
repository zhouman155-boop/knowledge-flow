# ── AI 模型（选一个填入）─────────────────────────────
# DeepSeek（推荐，国内直连，性价比高）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问（可选）
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── 数据存储目录 ──────────────────────────────────────
# 本地开发不需要设置（默认 ./data/）
# Railway 部署时设为 /data（对应持久磁盘挂载点）
# DATA_DIR=/data

# ── 服务端口 ──────────────────────────────────────────
# 本地开发默认 8000，Railway 会自动注入 PORT
# PORT=8000
